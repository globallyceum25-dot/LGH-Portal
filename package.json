{
  "name": "lyceum-global-holdings-portal",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Modernized corporate portal for Lyceum Global Holdings — sectors, companies and business profiles, with an admin CMS.",
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "dev:api": "bun --watch server/index.ts",
    "dev:web": "vite",
    "build": "vite build",
    "start": "NODE_ENV=production bun server/index.ts",
    "seed": "bun server/seed.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-force-graph-3d": "^1.29.1",
    "react-router-dom": "^7.1.1",
    "three": "^0.184.0",
    "three-spritetext": "^1.10.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
